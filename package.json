{
  "name": "@cyanheads/mcp-ts-core",
  "version": "0.2.10",
  "mcpName": "io.github.cyanheads/mcp-ts-core",
  "description": "Agent-native TypeScript framework for building MCP servers. Build tools, not infrastructure. Declarative definitions with auth, multi-backend storage, OpenTelemetry, and first-class support for Node.js and Cloudflare Workers.",
  "main": "dist/core/index.js",
  "types": "dist/core/index.d.ts",
  "files": [
    "dist/",
    "scripts/build.ts",
    "scripts/clean.ts",
    "scripts/devcheck.ts",
    "scripts/lint-mcp.ts",
    "scripts/tree.ts",
    "skills/",
    "templates/",
    "CLAUDE.md",
    "tsconfig.base.json",
    "vitest.config.base.ts",
    "biome.json"
  ],
  "bin": {
    "mcp-ts-core": "dist/cli/init.js"
  },
  "exports": {
    ".": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js"
    },
    "./worker": {
      "types": "./dist/core/worker.d.ts",
      "import": "./dist/core/worker.js"
    },
    "./tools": {
      "types": "./dist/mcp-server/tools/utils/toolDefinition.d.ts",
      "import": "./dist/mcp-server/tools/utils/toolDefinition.js"
    },
    "./resources": {
      "types": "./dist/mcp-server/resources/utils/resourceDefinition.d.ts",
      "import": "./dist/mcp-server/resources/utils/resourceDefinition.js"
    },
    "./prompts": {
      "types": "./dist/mcp-server/prompts/utils/promptDefinition.d.ts",
      "import": "./dist/mcp-server/prompts/utils/promptDefinition.js"
    },
    "./tasks": {
      "types": "./dist/mcp-server/tasks/utils/taskToolDefinition.d.ts",
      "import": "./dist/mcp-server/tasks/utils/taskToolDefinition.js"
    },
    "./errors": {
      "types": "./dist/types-global/errors.d.ts",
      "import": "./dist/types-global/errors.js"
    },
    "./config": {
      "types": "./dist/config/index.d.ts",
      "import": "./dist/config/index.js"
    },
    "./auth": {
      "types": "./dist/mcp-server/transports/auth/lib/checkScopes.d.ts",
      "import": "./dist/mcp-server/transports/auth/lib/checkScopes.js"
    },
    "./storage": {
      "types": "./dist/storage/core/StorageService.d.ts",
      "import": "./dist/storage/core/StorageService.js"
    },
    "./storage/types": {
      "types": "./dist/storage/core/IStorageProvider.d.ts",
      "import": "./dist/storage/core/IStorageProvider.js"
    },
    "./utils": {
      "types": "./dist/utils/index.d.ts",
      "import": "./dist/utils/index.js"
    },
    "./services": {
      "types": "./dist/services/index.d.ts",
      "import": "./dist/services/index.js"
    },
    "./linter": {
      "types": "./dist/linter/index.d.ts",
      "import": "./dist/linter/index.js"
    },
    "./testing": {
      "types": "./dist/testing/index.d.ts",
      "import": "./dist/testing/index.js"
    },
    "./testing/fuzz": {
      "types": "./dist/testing/fuzz.d.ts",
      "import": "./dist/testing/fuzz.js"
    },
    "./tsconfig.base.json": "./tsconfig.base.json",
    "./vitest.config": "./vitest.config.base.ts",
    "./biome": "./biome.json",
    "./package.json": "./package.json"
  },
  "type": "module",
  "sideEffects": [
    "./dist/config/index.js",
    "./dist/utils/internal/logger.js",
    "./dist/utils/telemetry/instrumentation.js",
    "./dist/utils/telemetry/metrics.js",
    "./dist/utils/telemetry/trace.js"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cyanheads/mcp-ts-core.git"
  },
  "bugs": {
    "url": "https://github.com/cyanheads/mcp-ts-core/issues"
  },
  "homepage": "https://github.com/cyanheads/mcp-ts-core#readme",
  "scripts": {
    "build": "bun run scripts/build.ts",
    "deploy:dev": "MCP_TRANSPORT_TYPE=http bunx wrangler dev",
    "deploy:prod": "MCP_TRANSPORT_TYPE=http bunx wrangler deploy",
    "start": "bun ./dist/index.js",
    "start:stdio": "MCP_TRANSPORT_TYPE=stdio bun ./dist/index.js",
    "start:http": "MCP_TRANSPORT_TYPE=http bun ./dist/index.js",
    "dev": "bun --watch src/index.ts",
    "dev:stdio": "MCP_LOG_LEVEL=debug MCP_TRANSPORT_TYPE=stdio bun --watch src/index.ts",
    "dev:http": "MCP_LOG_LEVEL=debug MCP_TRANSPORT_TYPE=http bun --watch src/index.ts",
    "devdocs": "bun run scripts/devdocs.ts",
    "devcheck": "bun run scripts/devcheck.ts",
    "rebuild": "bun run scripts/clean.ts && bun run build",
    "docs:generate": "bunx typedoc",
    "depcheck": "bunx depcheck",
    "lint": "biome check",
    "lint:mcp": "bun run scripts/lint-mcp.ts",
    "format": "biome check --write --unsafe",
    "typecheck": "bunx tsc --noEmit",
    "typecheck:scripts": "bunx tsc --project tsconfig.scripts.json --noEmit",
    "tree": "bun run scripts/tree.ts",
    "fetch-spec": "bun run scripts/fetch-openapi-spec.ts",
    "test": "bunx vitest run",
    "test:all": "bun run test && bun run test:integration",
    "test:integration": "bunx vitest run --config vitest.integration.ts",
    "test:fuzz": "bunx vitest run fuzz",
    "test:ui": "bunx vitest --ui",
    "test:coverage": "bunx vitest run --coverage",
    "audit": "bun audit",
    "audit:fix": "bun audit --fix",
    "publish-mcp": "bunx mcp-publisher publish"
  },
  "resolutions": {
    "@hono/node-server": "1.19.11",
    "chrono-node": "2.9.0",
    "diff": "8.0.4",
    "dotenv": "17.3.1",
    "brace-expansion": "1.1.13",
    "flatted": "3.4.2",
    "handlebars": "4.7.9",
    "hono": "4.12.9",
    "path-to-regexp": "8.4.0",
    "picomatch": "2.3.2",
    "yaml": "1.10.3",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.9",
    "@cloudflare/workers-types": "^4.20260329.1",
    "@hono/otel": "^1.1.1",
    "@opentelemetry/instrumentation-http": "^0.214.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.214.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.214.0",
    "@opentelemetry/instrumentation-pino": "^0.60.0",
    "@opentelemetry/resources": "^2.6.1",
    "@opentelemetry/sdk-metrics": "^2.6.1",
    "@opentelemetry/sdk-node": "^0.214.0",
    "@opentelemetry/sdk-trace-node": "^2.6.1",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@supabase/supabase-js": "^2.100.1",
    "@types/bun": "^1.3.11",
    "@types/diff": "^8.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.5.0",
    "@types/papaparse": "^5.5.2",
    "@types/sanitize-html": "^2.16.1",
    "@types/validator": "^13.15.10",
    "@vitest/coverage-istanbul": "4.1.2",
    "@vitest/ui": "4.1.2",
    "bun-types": "^1.3.11",
    "chrono-node": "^2.9.0",
    "clipboardy": "^5.3.1",
    "depcheck": "^1.4.7",
    "execa": "^9.6.1",
    "fast-check": "^4.6.0",
    "js-yaml": "^4.1.1",
    "ignore": "^7.0.5",
    "msw": "^2.12.14",
    "node-cron": "^4.2.1",
    "openai": "^6.33.0",
    "papaparse": "^5.5.3",
    "partial-json": "^0.1.7",
    "pdf-lib": "^1.17.1",
    "pino-pretty": "^13.1.3",
    "sanitize-html": "^2.17.2",
    "repomix": "^1.13.1",
    "tsc-alias": "^1.8.16",
    "typedoc": "^0.28.18",
    "typescript": "^6.0.2",
    "unpdf": "^1.4.0",
    "validator": "^13.15.26",
    "vite": "8.0.3",
    "vitest": "^4.1.2"
  },
  "keywords": [
    "agent",
    "agent-native",
    "ai",
    "ai-agent",
    "cloudflare-workers",
    "declarative",
    "edge",
    "framework",
    "llm",
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "observability",
    "opentelemetry",
    "tools",
    "typescript"
  ],
  "author": "cyanheads <casey@caseyjhand.com> (https://github.com/cyanheads/mcp-ts-core#readme)",
  "license": "Apache-2.0",
  "funding": [
    {
      "type": "github",
      "url": "https://github.com/sponsors/cyanheads"
    },
    {
      "type": "buy_me_a_coffee",
