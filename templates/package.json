{
  "name": "{{PACKAGE_NAME}}",
  "version": "0.1.0",
  "description": "",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "{{PACKAGE_NAME}}": "dist/index.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE",
    "CLAUDE.md",
    "AGENTS.md",
    "Dockerfile",
    "server.json"
  ],
  "scripts": {
    "build": "tsx scripts/build.ts",
    "rebuild": "tsx scripts/clean.ts && tsx scripts/build.ts",
    "clean": "tsx scripts/clean.ts",
    "devcheck": "tsx scripts/devcheck.ts",
    "tree": "tsx scripts/tree.ts",
    "format": "biome check --write --unsafe .",
    "lint:mcp": "tsx scripts/lint-mcp.ts",
    "test": "vitest run",
    "dev:stdio": "tsx --watch src/index.ts",
    "dev:http": "MCP_TRANSPORT_TYPE=http tsx --watch src/index.ts",
    "start:stdio": "node dist/index.js",
    "start:http": "MCP_TRANSPORT_TYPE=http node dist/index.js"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "model-context-protocol"
  ],
  "repository": {
    "type": "git",
    "url": ""
  },
  "license": "Apache-2.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@cyanheads/mcp-ts-core": "^{{FRAMEWORK_VERSION}}",
    "pino-pretty": "^13.1.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "@types/node": "^25.5.0",
    "ignore": "^7.0.5",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.19.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
