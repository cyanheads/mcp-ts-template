      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "histogram_quantile(0.95, sum by (mcp_tool_name, le) (rate(mcp_tool_input_bytes_bucket{service_name=~\"(?:@[^/]+/)?(?:$service)\"}[$__rate_interval])))", "legendFormat": "{{mcp_tool_name}}", "refId": "A" }]
