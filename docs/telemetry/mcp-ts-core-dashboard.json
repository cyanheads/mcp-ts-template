{
  "annotations": { "list": [] },
  "description": "Example Grafana dashboard for @cyanheads/mcp-ts-core OpenTelemetry metrics. Drop-in for any Prometheus-compatible backend. See docs/telemetry/dashboards.md for import guide and vendor-agnostic query recipes.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "liveNow": false,
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["mcp", "mcp-ts-core", "opentelemetry"],
  "templating": {
    "list": [
      {
        "current": { "selected": false, "text": "Prometheus", "value": "prometheus" },
        "hide": 0,
        "includeAll": false,
        "label": "Data source",
        "multi": false,
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "regex": "",
        "skipUrlSync": false,
        "type": "datasource"
      },
      {
        "current": { "selected": true, "text": ".+", "value": ".+" },
        "description": "Regex for service.name. Strips any @scope/ prefix automatically — enter just 'mcp-ts-core' to match '@cyanheads/mcp-ts-core'.",
        "hide": 0,
        "label": "Service",
        "name": "service",
        "options": [{ "selected": true, "text": ".+", "value": ".+" }],
        "query": ".+",
        "skipUrlSync": false,
        "type": "textbox"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "mcp-ts-core",
  "uid": "mcp-ts-core",
  "version": 1,
  "weekStart": "",
  "panels": [
    { "id": 1, "type": "row", "title": "Live activity", "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }, "panels": [] },
    {
      "id": 2, "type": "stat", "title": "Tool calls",
      "description": "Total tool calls over the selected time range.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] } } },
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "sum(increase(mcp_tool_calls_total{service_name=~\"(?:@[^/]+/)?(?:$service)\"}[$__range]))", "refId": "A" }]
    },
    {
      "id": 3, "type": "stat", "title": "Active requests",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 50 }, { "color": "red", "value": 200 }] } } },
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "sum(mcp_requests_active{service_name=~\"(?:@[^/]+/)?(?:$service)\"})", "refId": "A" }]
    },
    {
      "id": 4, "type": "stat", "title": "Active sessions",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] } } },
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "sum(mcp_sessions_active{service_name=~\"(?:@[^/]+/)?(?:$service)\"})", "refId": "A" }]
    },
    {
      "id": 5, "type": "stat", "title": "Tool error rate",
      "description": "Errors as a percentage of total tool calls over the selected time range.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "percent", "decimals": 2, "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 5 }] } } },
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "100 * sum(increase(mcp_tool_errors_total{service_name=~\"(?:@[^/]+/)?(?:$service)\"}[$__range])) / clamp_min(sum(increase(mcp_tool_calls_total{service_name=~\"(?:@[^/]+/)?(?:$service)\"}[$__range])), 1)", "refId": "A" }]
    },
    {
      "id": 6, "type": "timeseries", "title": "Tool calls / sec by tool",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 5 },
      "fieldConfig": { "defaults": { "unit": "cps", "custom": { "drawStyle": "line", "fillOpacity": 10, "lineInterpolation": "smooth", "lineWidth": 1, "stacking": { "mode": "normal", "group": "A" } }, "color": { "mode": "palette-classic" } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "sum by (mcp_tool_name) (rate(mcp_tool_calls_total{service_name=~\"(?:@[^/]+/)?(?:$service)\"}[$__rate_interval]))", "legendFormat": "{{mcp_tool_name}}", "refId": "A" }]
    },
    {
      "id": 7, "type": "timeseries", "title": "Tool errors / sec by category",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 5 },
      "fieldConfig": { "defaults": { "unit": "cps", "custom": { "drawStyle": "line", "fillOpacity": 10, "lineInterpolation": "smooth", "lineWidth": 1, "stacking": { "mode": "normal", "group": "A" } }, "color": { "mode": "palette-classic" } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "sum by (mcp_tool_error_category) (rate(mcp_tool_errors_total{service_name=~\"(?:@[^/]+/)?(?:$service)\"}[$__rate_interval]))", "legendFormat": "{{mcp_tool_error_category}}", "refId": "A" }]
    },

    { "id": 10, "type": "row", "title": "Tools", "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 13 }, "panels": [] },
    {
      "id": 11, "type": "timeseries", "title": "Per-tool call rate",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "fieldConfig": { "defaults": { "unit": "cps", "custom": { "drawStyle": "line", "fillOpacity": 10, "lineInterpolation": "smooth", "lineWidth": 1 }, "color": { "mode": "palette-classic" } } },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "sum by (mcp_tool_name) (rate(mcp_tool_calls_total{service_name=~\"(?:@[^/]+/)?(?:$service)\"}[$__rate_interval]))", "legendFormat": "{{mcp_tool_name}}", "refId": "A" }]
    },
    {
      "id": 12, "type": "timeseries", "title": "Per-tool p95 duration",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "fieldConfig": { "defaults": { "unit": "ms", "custom": { "drawStyle": "line", "fillOpacity": 5, "lineInterpolation": "smooth", "lineWidth": 1 }, "color": { "mode": "palette-classic" } } },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "histogram_quantile(0.95, sum by (mcp_tool_name, le) (rate(mcp_tool_duration_milliseconds_bucket{service_name=~\"(?:@[^/]+/)?(?:$service)\"}[$__rate_interval])))", "legendFormat": "{{mcp_tool_name}}", "refId": "A" }]
    },
    {
      "id": 13, "type": "timeseries", "title": "Tool input bytes (p95)",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
