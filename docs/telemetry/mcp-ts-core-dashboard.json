    { "id": 80, "type": "row", "title": "Per-request leak detection (HTTP transport)", "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 140 }, "panels": [] },
    {
      "id": 81, "type": "timeseries", "title": "Per-request created vs finalized",
      "description": "Persistent gap between rates indicates per-request McpServer/transport instances are not being reclaimed.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 141 },
      "fieldConfig": { "defaults": { "unit": "cps", "custom": { "drawStyle": "line", "fillOpacity": 5, "lineInterpolation": "smooth", "lineWidth": 1 }, "color": { "mode": "palette-classic" } } },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "sum by (kind) (rate(mcp_http_per_request_created_total{service_name=~\"(?:@[^/]+/)?(?:$service)\"}[$__rate_interval]))", "legendFormat": "{{kind}} created", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "sum by (kind) (rate(mcp_http_per_request_finalized_total{service_name=~\"(?:@[^/]+/)?(?:$service)\"}[$__rate_interval]))", "legendFormat": "{{kind}} finalized", "refId": "B" }
      ]
    },
    {
      "id": 82, "type": "timeseries", "title": "Cumulative leak gap (created − finalized)",
      "description": "Growing line over time = leak. Should be flat under steady-state load.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 141 },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 10, "lineInterpolation": "smooth", "lineWidth": 1 }, "color": { "mode": "palette-classic" } } },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [{ "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "sum by (kind) (mcp_http_per_request_created_total{service_name=~\"(?:@[^/]+/)?(?:$service)\"}) - sum by (kind) (mcp_http_per_request_finalized_total{service_name=~\"(?:@[^/]+/)?(?:$service)\"})", "legendFormat": "{{kind}}", "refId": "A" }]
