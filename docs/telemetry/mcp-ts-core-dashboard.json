      "targets": [{ "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "histogram_quantile(0.95, sum by (mcp_resource_name, le) (rate(mcp_resource_duration_milliseconds_bucket{service_name=~\"(?:@[^/]+/)?(?:$service)\"}[$__rate_interval])))", "legendFormat": "{{mcp_resource_name}}", "refId": "A" }]
